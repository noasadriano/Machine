type MetricKey = keyof Omit<Equipment, 'id' | 'manufacturer' | 'model'>

interface Column {
  key: MetricKey
  label: string
  unit: string
  direction: 'max' | 'min'
}

function getColumns(category: Category): Column[] {
  return [
    { key: 'payload', label: category === 'Trucks' ? 'Payload' : 'Bucket Capacity', unit: category === 'Trucks' ? 't' : 'm³', direction: 'max' },
    { key: 'enginePower', label: 'Engine Power', unit: 'kW', direction: 'max' },
    { key: 'fuelConsumption', label: 'Fuel Consumption', unit: 'L/h', direction: 'min' },
    { key: 'mtbf', label: 'MTBF', unit: 'h', direction: 'max' },
    { key: 'mttr', label: 'MTTR', unit: 'h', direction: 'min' },
    { key: 'availability', label: 'Availability', unit: '%', direction: 'max' },
  ]
}

function formatMetric(value: number) {
  return value.toFixed(1)
}

function currencyM(value: number) {
  return `$${value.toFixed(2)}M`
}

function exportReport() {

const HOURS_PER_YEAR = 5000
const YEARS = 5
const HOURS_5Y = HOURS_PER_YEAR * YEARS

function tcoBreakdown(item: Equipment) {
  const operating = (item.operatingCost * HOURS_5Y) / 1e6
  const maintenance = item.maintenanceCostPerYear * YEARS
  return {
    purchase: item.purchasePrice,
    operating,
    maintenance,
    total: item.purchasePrice + operating + maintenance,
  }
}


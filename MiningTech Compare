  )
}

function MetricBarChart({ title, data, metricKey, unit, inverse = false }: { title: string; data: Equipment[]; metricKey: MetricKey; unit: string; inverse?: boolean }) {
  const values = data.map((d) => d[metricKey])
  const max = Math.max(...values)
  const min = Math.min(...values)
  const range = max - min || 1

  const width = (value: number) => {
    const normalized = inverse ? (max - value) / range : (value - min) / range
    return Math.max(5, normalized * 100)
  }

  return (
    <div className='bg-white rounded-xl border border-slate-200 p-6 shadow-sm'>
      <div className='flex items-center justify-between mb-5'>
        <h3 className='font-semibold text-slate-800'>{title}</h3>
        <span className='text-xs font-medium text-slate-500 uppercase tracking-wider'>{unit}</span>
      </div>
      <div className='space-y-4'>
        {data.map((item) => (
          <div key={item.id} className='space-y-1'>
            <div className='flex justify-between text-sm'>
              <span className='font-medium text-slate-700'>{item.manufacturer} {item.model}</span>
              <span className='text-slate-600'>{formatMetric(item[metricKey])} {unit}</span>
            </div>
            <div className='h-2.5 w-full bg-slate-100 rounded-full overflow-hidden'>
              <div className={`h-full rounded-full ${manufacturerTheme[item.manufacturer].bar}`} style={{ width: `${width(item[metricKey])}%` }} />
            </div>
          </div>
        ))}
      </div>
    </div>
  )
}

function ComparisonCards({ data, columns }: { data: Equipment[]; columns: Column[] }) {
  return (
    <div className='md:hidden print-hidden space-y-4'>
      {data.map((item) => (
        <div
          key={item.id}
          className='bg-white rounded-xl border border-slate-200 p-5 shadow-sm'
        >
          <div className='flex items-center justify-between mb-4'>
            <div>
              <p className='text-xs text-slate-500 uppercase tracking-wider'>{item.manufacturer}</p>
              <p className='text-lg font-bold text-slate-900'>{item.model}</p>
            </div>
            <span className={`inline-flex items-center gap-1.5 px-2.5 py-1 rounded-full text-xs font-semibold border ${manufacturerTheme[item.manufacturer].badge}`}>
              {item.manufacturer}
            </span>
          </div>
          <div className='grid grid-cols-2 gap-3'>
            {columns.map((col) => {
              const vals = data.map((d) => d[col.key])
              const best = col.direction === 'max' ? Math.max(...vals) : Math.min(...vals)
              const worst = col.direction === 'max' ? Math.min(...vals) : Math.max(...vals)
              const value = item[col.key]
              const isBest = value === best
              const isWorst = value === worst
              return (
                <div key={col.key} className='bg-slate-50 rounded-lg p-3'>
                  <p className='text-xs text-slate-500 mb-1'>
                    {col.label} <span className='text-slate-400'>({col.unit})</span>
                  </p>
                  <p className={`text-sm font-semibold ${isBest ? 'text-emerald-700' : isWorst ? 'text-rose-700' : 'text-slate-900'}`}>
                    {formatMetric(value)}
                  </p>
                </div>
              )
            })}
          </div>
        </div>
      ))}
      <div className='px-2 text-xs text-slate-500 flex items-center gap-4'>
        <span className='flex items-center gap-1.5'>
          <span className='w-3 h-3 rounded bg-emerald-100 border border-emerald-300' />
          Melhor indicador
        </span>
        <span className='flex items-center gap-1.5'>
          <span className='w-3 h-3 rounded bg-rose-100 border border-rose-300' />
          Indicador crítico
        </span>
      </div>
    </div>
  )
}

